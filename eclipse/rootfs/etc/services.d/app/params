#!/bin/sh

set -e # Exit immediately if a command exits with a non-zero status.
set -u # Treat unset variables as an error.

# Set location of profile.
echo "--profile"
echo "/config/profile"

# Make sure we don't get ask to be the default browser.
echo "--setDefaultBrowser"

# Check if kiosk mode is enabled.
if is-bool-val-true "${ECLIPSE_KIOSK:-0}"; then
    echo "--kiosk"
fi

# URL to open.
# NOTE: This should be the last argument.
if [ -n "${ECLIPSE_OPEN_URL:-}" ]; then
    echo "$ECLIPSE_OPEN_URL"
fi

# Custom arguments.
if [ -n "${ECLIPSE_CUSTOM_ARGS:-}" ]; then
    eval 'for word in '$ECLIPSE_CUSTOM_ARGS'; do echo "$word"; done'
fi
